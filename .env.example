# Band.ai / Thenvoi integration
# "Thenvoi" remains the load-bearing internal identifier for package/env/API
# names. User-facing copy says "Band". Do not rename these env vars without an
# explicit migration.

# Required. Issued by Band when you register the agent.
THENVOI_AGENT_ID=
THENVOI_API_KEY=

# Optional. Defaults to https://app.thenvoi.com when unset.
THENVOI_BASE_URL=

# Optional. UUID of the Band user who owns this agent. Used by the contact
# hub-room strategy (added as the room owner) and by other privileged paths
# that need to address the owner directly. Falls back to GET /agent/me when
# unset, so this is only required if that endpoint isn't available.
THENVOI_OWNER_ID=

# Memory tools — exposes mcp__nanoclaw__band_list_memories,
# band_store_memory, band_supersede_memory, etc. to the agent. When false,
# the agent has no platform memory at all (local CLAUDE.md / CLAUDE.local.md
# still works).
THENVOI_MEMORY_TOOLS=false

# When true (and the channel is Band), the container fetches each room
# participant's stored memories at startup and appends them to the system
# prompt as `## Existing Memories About Room Participants`. Also injects
# a synthetic `[System]` message into the room when a new participant joins
# mid-session (`participant_added`), with up to 10 of that participant's
# memories. No-op unless THENVOI_MEMORY_TOOLS is also enabled (otherwise
# memory loading and consolidation are disabled with the memory tools).
THENVOI_MEMORY_LOAD_ON_START=false

# When true (and the channel is Band), the container runs a one-shot
# memory-consolidation pass against the SAME provider session right after
# the poll loop exits (typically on SIGTERM from `docker stop`). The pass
# can call memory tools but cannot call chat, event, contact, participant,
# room, or peer tools. Output is drained, not delivered. Memory consolidation
# only runs when THENVOI_MEMORY_TOOLS is also enabled.
THENVOI_MEMORY_CONSOLIDATION=false

# Contact-event strategy: what the host does when Band emits a
# contact_request_received / contact_added / contact_removed event for
# this agent.
#
#   disabled  — drop the event silently (default). The agent never sees
#               contacts; outbound contact tools still work.
#   hub_room  — lazily provision a per-agent "Contact Hub" Band chat room
#               (THENVOI_OWNER_ID added as a member), persist its room id
#               in the central DB, wire it to THENVOI_CONTACT_AGENT_GROUP_ID
#               (or the only agent group when exactly one exists), and forward
#               every contact event into the hub as a synthetic message.
#               The owner replies in the hub room.
THENVOI_CONTACT_STRATEGY=disabled
# Optional. Agent group that should handle Contact Hub synthetic messages.
# If unset and exactly one agent group exists, NanoClaw uses that group.
THENVOI_CONTACT_AGENT_GROUP_ID=
